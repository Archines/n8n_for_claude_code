{
  "name": "[Webhook] Slack通知 - Webhook受信→Slack送信",
  "description": "Webhook受信→メッセージ整形→Slack通知のテンプレート",
  "_metadata": {
    "template_name": "webhook-slack",
    "description": "Webhook受信→Slack通知",
    "trigger_type": "webhook"
  },
  "nodes": [
    {
      "id": "1a2b3c4d-5e6f-4a7b-8c9d-0e1f2a3b4c5d",
      "name": "Webhookリクエスト受信",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "2b3c4d5e-6f7a-4b8c-9d0e-1f2a3b4c5d6e",
      "parameters": {
        "httpMethod": "POST",
        "path": "my-webhook"
      }
    },
    {
      "id": "3c4d5e6f-7a8b-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "Slackメッセージ整形",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300],
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "# Webhook受信データからSlackメッセージを整形\nresults = []\nfor item in _items:\n    data = item[\"json\"]\n    message = f\"通知: {data}\"\n    results.append({\"json\": {\"message\": message}})\nreturn results"
      }
    },
    {
      "id": "4d5e6f7a-8b9c-4d0e-1f2a-3b4c5d6e7f8a",
      "name": "Slack通知送信",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [750, 300],
      "credentials": {
        "slackOAuth2Api": {
          "id": "__PLACEHOLDER__",
          "name": "__PLACEHOLDER__"
        }
      },
      "parameters": {
        "resource": "message",
        "operation": "send",
        "channel": {
          "__rl": true,
          "value": "#general",
          "mode": "name"
        },
        "text": "={{ $json.message }}"
      }
    }
  ],
  "connections": {
    "Webhookリクエスト受信": {
      "main": [
        [
          {
            "node": "Slackメッセージ整形",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Slackメッセージ整形": {
      "main": [
        [
          {
            "node": "Slack通知送信",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
